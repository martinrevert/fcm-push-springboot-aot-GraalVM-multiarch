{
  "resources": {
    "includes": [
      {
        "pattern": "org/mariadb/jdbc/.*"
      },
      {
        "pattern": "META-INF/services/java.sql.Driver"
      },
      {
        "pattern": "application.properties"
      },
      {
        "pattern": "admin_sdk.properties"
      },
      {
        "pattern": "org/hibernate/hibernate-mapping-3.0.dtd"
      },
      {
        "pattern": "org/hibernate/.*\\.dtd"
      },
      {
        "pattern": "org/hibernate/.*\\.xsd"
      }
    ]
  }
}
